# ==========================================
# ENVIRONMENTS PARA DEPLOY NA VERCEL
# ==========================================
# Crie essas variáveis na aba "Settings > Environment Variables" do seu projeto na Vercel

# 1. Banco de Dados Neon
# String de conexão completa do banco Neon.
# Exemplo: postgresql://[USER]:[PASSWORD]@[HOST]/[DB]?sslmode=require
DATABASE_URL=

# 2. Segurança do Painel
# Chave secreta usada para gerar os tokens de autenticação (JWT) do painel de administração.
# Pode ser qualquer string complexa e longa.
JWT_SECRET=

# 3. Evolution API (WhatsApp)
# URL base da sua API instalada.
VITE_EVOLUTION_API_URL=https://api.2b.app.br
# A Global API Key configurada na sua Evolution.
VITE_EVOLUTION_API_KEY=d037768b3d06382756a0d9edecf3e40e

# 4. Configuração de Grupos (WhatsApp Alertas)
# O ID (JID) do grupo interno onde os leads irão cair.
LEAD_ALERT_GROUP_JID=120363406751423640@g.us
